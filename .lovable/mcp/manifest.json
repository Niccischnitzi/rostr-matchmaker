{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://logxhkpurkurikbgsmrl.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "rostr-mcp",
      "version": "0.1.0",
      "title": "Rostr"
    },
    "tools": [
      {
        "name": "get_my_profile",
        "title": "Get my profile",
        "description": "Return the signed-in Rostr user's profile row (username, display name, avatar, bio).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "search_users",
        "title": "Search Rostr users",
        "description": "Search public Rostr profiles by username or display name. Returns up to 20 matches.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Text to match against username or display_name."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20,
              "description": "Max results (default 10)."
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_friends",
        "title": "List my friends",
        "description": "List the signed-in user's accepted Rostr friends.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_conversations",
        "title": "List my DM conversations",
        "description": "List the signed-in user's DM conversations, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "send_direct_message",
        "title": "Send a direct message",
        "description": "Send a DM to another Rostr user in an existing conversation.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "conversation_id": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the conversation to post into."
            },
            "body": {
              "type": "string",
              "minLength": 1,
              "maxLength": 2000,
              "description": "Message text."
            }
          },
          "required": [
            "conversation_id",
            "body"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "post_lfg_ad",
        "title": "Post an LFG ad",
        "description": "Post a Looking-For-Group ad on Rostr as the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 3,
              "maxLength": 120,
              "description": "Short headline for the ad."
            },
            "game": {
              "type": "string",
              "minLength": 1,
              "maxLength": 60,
              "description": "Game name (e.g. 'Valorant')."
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1000,
              "description": "Details about who you're looking for."
            }
          },
          "required": [
            "title",
            "game",
            "description"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_open_lfg_ads",
        "title": "Browse open LFG ads",
        "description": "List currently open LFG ads on Rostr, optionally filtered by game. Newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "game": {
              "type": "string",
              "minLength": 1,
              "maxLength": 60,
              "description": "Filter by game name."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "description": "Max results (default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_my_wallet",
        "title": "Get my Shards wallet",
        "description": "Return the signed-in user's Rostr Shards balance and recent transactions.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
